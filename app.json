{
  "expo": {
    "name": "Sides",
    "slug": "sides",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sides",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEEDFE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sides.app",
      "associatedDomains": ["applinks:sides.app"],
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Sides needs speech recognition to auto-advance when you speak your lines.",
        "NSMicrophoneUsageDescription": "Sides needs microphone access to listen while you rehearse your lines.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEEDFE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.sides.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Sides needs microphone access to listen while you rehearse your lines.",
          "speechRecognitionPermission": "Sides needs speech recognition to auto-advance when you speak your lines."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9adb6c9d-2da9-43b6-8627-c5e8d5ed8285"
      }
    }
  }
}
